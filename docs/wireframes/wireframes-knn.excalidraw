    {
      "id": "U4ghQB5ZE5FU_cX8TrA5y",
      "type": "text",
      "x": 3828.49202697884,
      "y": 1203.353775785128,
      "width": 583.2171630859375,
      "height": 240,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bEA",
      "roundness": null,
      "seed": 103947465,
      "version": 1084,
      "versionNonce": 953837122,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1745878182823,
      "link": null,
      "locked": false,
      "text": "Ao invés de uma tela de agendamentos, A primeira\ntela é a 'Home', tendo uma faixa de seleção logo abaixo do\nnome do barbeiro indicando o dia de hoje, mas que ele pode \ndeslizar para outros dias\n\nPara cada dia, aparece os agendamentos do dia e os horários\nvagos. O barbeiro pode clicar no horário que está preenchido e enxergar \nos detalhes (os serviços, preço, forma de pagamento, cliente...)\n\nEle pode selecionar um horário qualquer e terá um icone de 'bloquear'.\nAssim, ele diz uma justificativa e o horário estará bloqueado (independente\nse for um horário marcado ou não)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Ao invés de uma tela de agendamentos, A primeira\ntela é a 'Home', tendo uma faixa de seleção logo abaixo do\nnome do barbeiro indicando o dia de hoje, mas que ele pode \ndeslizar para outros dias\n\nPara cada dia, aparece os agendamentos do dia e os horários\nvagos. O barbeiro pode clicar no horário que está preenchido e enxergar \nos detalhes (os serviços, preço, forma de pagamento, cliente...)\n\nEle pode selecionar um horário qualquer e terá um icone de 'bloquear'.\nAssim, ele diz uma justificativa e o horário estará bloqueado (independente\nse for um horário marcado ou não)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "cUYBELRiwk52fAkCBfKVE",
      "type": "line",
      "x": 2535.6322567510933,
      "y": 2902.647680234888,
      "width": 295.2780556994594,
      "height": 1.3182056058012677,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
